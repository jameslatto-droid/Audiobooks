# ─────────────────────────────────────────────────────────────────────────────
# AquaCenyx Audiobook Server — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Timezone (match host timezone)
TZ=Europe/Amsterdam

# Audiobookshelf local port (only reachable from the host, not exposed publicly)
AUDIOBOOKSHELF_PORT=13378

# Public domain (used in Traefik labels)
DOMAIN=audiobooks.aquacenyx.nl
